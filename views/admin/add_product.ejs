<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yeni Ürün Ekle | Admin Paneli</title>
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background: #2c3e50;
            color: white;
            padding-top: 20px;
        }

        .sidebar a {
            color: #bdc3c7;
            display: block;
            padding: 15px;
            text-decoration: none;
            transition: 0.3s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background: #34495e;
            color: white;
            border-left: 4px solid #d4af37;
        }

        .main-content {
            padding: 30px;
        }

        .gold-text {
            color: #d4af37;
        }

        .form-section {
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
            padding: 24px;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 sidebar">
                <h4 class="text-center gold-text mb-4">Yönetim Paneli</h4>
                <a href="/admin"><i class="fas fa-tachometer-alt mr-2"></i> Dashboard</a>
                <a href="/admin/products"><i class="fas fa-box mr-2"></i> Ürünler</a>
                <a href="/admin/products/add"><i class="fas fa-plus mr-2"></i> Yeni Ürün Ekle</a>
                <a href="/admin/orders"><i class="fas fa-shopping-cart mr-2"></i> Siparişler</a>
                <a href="/admin/users"><i class="fas fa-users mr-2"></i> Kullanıcılar</a>
                <a href="/"><i class="fas fa-external-link-alt mr-2"></i> Siteye Git</a>
                <a href="/auth/logout" class="mt-5 text-danger"><i class="fas fa-sign-out-alt mr-2"></i> Çıkış Yap</a>
            </div>
            <div class="col-md-10 main-content">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2>Yeni Ürün Ekle</h2>
                        <p class="text-muted mb-0">Buradan yeni ürün bilgilerini ekleyebilirsiniz.</p>
                    </div>
                    <a href="/admin/products" class="btn btn-secondary">Geri Dön</a>
                </div>

                <div class="form-section">
                    <form action="/admin/products/add" method="POST" enctype="multipart/form-data">
                        <div class="row">
                            <div class="col-lg-8">
                                <div class="form-group">
                                    <label>Ürün Adı</label>
                                    <input type="text" name="name" class="form-control" required>
                                </div>
                                <div class="form-group">
                                    <label>Açıklama</label>
                                    <textarea name="description" class="form-control" rows="5" required></textarea>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Fiyat (₺)</label>
                                            <input type="number" name="price" class="form-control" step="0.01" min="0" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Stok</label>
                                            <input type="number" name="stock" class="form-control" value="1" min="0" required>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Kategoriler</label>
                                    <select name="categories" class="form-control" multiple style="height: 140px;">
                                        <% categories.forEach(cat => { %>
                                            <option value="<%= cat._id %>"><%= cat.name %></option>
                                        <% }) %>
                                    </select>
                                    <small class="text-muted">Ctrl / Cmd ile birden fazla kategori seçebilirsiniz.</small>
                                </div>
                                <div class="form-check mb-4">
                                    <input type="checkbox" name="isPopular" class="form-check-input" id="isPopular">
                                    <label class="form-check-label" for="isPopular">Öne Çıkan Ürün (Ana Sayfada Göster)</label>
                                </div>
                                <div class="col-lg-4">
                                    <div class="form-group">
                                        <label>Ana Görsel</label>
                                        <input type="file" name="imageFile" class="form-control-file" accept="image/*" required>
                                    </div>
                                </div>
                        </div>
                        <div class="mt-4 d-flex justify-content-between">
                            <a href="/admin/products" class="btn btn-secondary">İptal</a>
                            <button type="submit" class="btn btn-warning">Ürünü Kaydet</button>
                        </div>
                    </form>
                </div>

                <div class="mt-5 form-section">
                    <h4 class="mb-4">Mevcut Ürünler</h4>
                    <% if (products && products.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 90px;">Görsel</th>
                                        <th>Ürün Adı</th>
                                        <th>Kategori</th>
                                        <th>Fiyat</th>
                                        <th>Stok</th>
                                        <th>Durum</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% products.forEach(product => { %>
                                        <tr>
                                            <td><img src="<%= product.imageUrl %>" alt="" style="width: 70px; height: 70px; object-fit: cover; border-radius: 6px;"></td>
                                            <td><%= product.name %></td>
                                            <td>
                                                <% if (product.categories && product.categories.length > 0) { %>
                                                    <%= product.categories.map(c => c.name || '').join(', ') %>
                                                <% } else { %>
                                                    Kategorisiz
                                                <% } %>
                                            </td>
                                            <td>₺<%= product.price.toLocaleString('tr-TR') %></td>
                                            <td><%= product.stock %></td>
                                            <td><span class="badge badge-<%= product.stock > 0 ? 'success' : 'secondary' %>"><%= product.stock > 0 ? 'Stokta' : 'Tükenmiş' %></span></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="alert alert-info mb-0">Henüz eklenmiş ürün yok.</div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script src="/assets/js/vendor/jquery-1.12.4.min.js"></script>
    <script src="/assets/js/bootstrap.min.js"></script>
</body>

</html>
