                        </p>

                        <!-- Ring Interactive Circle Area -->
                        <div
                            style="height: 150px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; position: relative;">
                            <div id="mring-measure-circle-h"
                                style="width: 140px; height: 140px; border-radius: 50%; border: 2.5px solid #140C40; background: transparent; transition: width 0.05s ease, height 0.05s ease; box-shadow: 0 0 12px rgba(20, 12, 64, 0.12); display: flex; align-items: center; justify-content: center;">
                                <div
                                    style="width: 100%; height: 100%; border-radius: 50%; border: 1px dashed #c5a059; opacity: 0.8;">
                                </div>
                            </div>
                        </div>

