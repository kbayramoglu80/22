                    <div style="display: flex; justify-content: center; gap: 8px; margin-bottom: 20px;">
                        <button type="button" id="mtab-btn-ring-h" class="measure-tab-btn active"
                            onclick="switchModalMeasureModeHome('ring')"
                            style="padding:6px 14px; font-size:11px; font-weight:700; border-radius:20px; border:1px solid #c5a059; background:#c5a059; color:#fff; cursor:pointer; outline:none; transition: all 0.3s;">Mevcut
                            Yüzük ile Ölç</button>
                        <button type="button" id="mtab-btn-circles-h" class="measure-tab-btn"
                            onclick="switchModalMeasureModeHome('circles')"
                            style="padding:6px 14px; font-size:11px; font-weight:700; border-radius:20px; border:1px solid #ccc; background:#fff; color:#555; cursor:pointer; outline:none; transition: all 0.3s;">Ölçü
                            Seçip Karşılaştır</button>
                    </div>

                    <!-- Mode A: Measure Existing Ring -->
                    <div id="mmode-content-ring-h" style="display: block;">
