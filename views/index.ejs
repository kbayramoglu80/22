<%- include('partials/head') %>
    <%- include('partials/header') %>

        <main>
            <style>
                /* Hero ile altındaki bölüm arasındaki boşluğu azaltma */
                .new-arrival.hero-adjacent-section {
                    padding-top: 15px !important;
                }

                .slider-area {
                    margin-top: 170px;
                    padding-top: 0;
                }

                .hero__caption h1 {
                    font-size: 3.2rem;
                    font-weight: 800;
                    letter-spacing: -0.03em;
                    text-shadow: 0 8px 30px rgba(0,0,0,0.24);
                }

                .hero__caption .hero-cta {
                    background: rgba(255,255,255,0.96) !important;
                    color: #140c40 !important;
                    border-radius: 999px;
                    padding: 13px 28px;
                    font-weight: 700;
                    box-shadow: 0 12px 30px rgba(0,0,0,0.18);
                    transition: transform 0.2s ease, box-shadow 0.2s ease;
                }

                .hero__caption .hero-cta:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 16px 36px rgba(0,0,0,0.24);
                }

                .section-tittle h2 {
                    font-size: 2rem;
                    font-weight: 800;
                    color: #140c40;
                    letter-spacing: -0.02em;
                    margin-bottom: 10px;
                }

                .section-tittle p {
                    color: #6b7280;
                    font-size: 1rem;
                    line-height: 1.7;
                }

                @media (max-width: 991px) {
                    .slider-area {
                        margin-top: 24px;
                    }
                }

                @media (max-width: 767px) {
                    .slider-area .hero__caption {
                        padding: 0 12px !important;
                    }

                    .slider-area .hero__caption h1 {
                        font-size: 28px;
                        /* Mobilde daha okunaklı ve dengeli bir yazı boyutu */
                        line-height: 1.2;
                        margin-bottom: 18px;
                    }
                }

                @media (max-width: 575px) {
                    .slider-area .hero__caption h1 {
                        font-size: 24px;
                    }
                }
                /* Desktop banner displayed as image to avoid cropping */
                .home-banner {
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    padding: 0;
                    background-color: transparent;
                    margin: 0;
                    border: none;
                    box-shadow: none;
                    animation: bannerReveal 1s ease both;
                }

                @keyframes bannerReveal {
                    from {
                        opacity: 0;
                        transform: translateY(16px) scale(0.98);
                    }
                    to {
                        opacity: 1;
                        transform: translateY(0) scale(1);
                    }
                }

                .home-banner-img {
                    width: 100%;
                    height: auto;
                    max-height: 680px; /* desktop visual limit */
                    object-fit: contain;
                    display: block;
                    margin: 0 auto;
                    border: none;
                    box-shadow: none;
                    padding: 0;
                    animation: bannerImageFade 1.2s ease both;
                }

                @keyframes bannerImageFade {
                    from {
                        opacity: 0;
                        filter: blur(6px);
                    }
                    to {
                        opacity: 1;
                        filter: blur(0);
                    }
                }

                /* Full-bleed variant: stretches the image to viewport edges */
                .home-banner-img.full-bleed {
                    width: 100vw;
                    max-width: none;
                    margin-left: calc(50% - 50vw);
                    margin-right: calc(50% - 50vw);
                }

                @media (max-width: 1199px) {
                    .home-banner-img { max-height: 620px; }
                }

                @media (max-width: 991px) {
                    .home-banner-img { max-height: 520px; }
                }

                @media (max-width: 767px) {
                    .home-banner-img {
                        max-height: 360px;
                        width: 100%;
                    }
                }

                @media (max-width: 575px) {
                    .home-banner-img { max-height: 260px; }
                }
            </style>

            <!--? Hero Area Removed: Show products directly -->

            <div class="home-support-section">
                <div class="container">
                    <div class="row justify-content-center mb-40">
                        <div class="col-xl-7 col-lg-8 col-md-10 text-center">
                            <div class="section-tittle mb-20">
                                <h2><%= t('new_arrival_title','Alina İçin Destek') %></h2>
                                <p><%= t('new_arrival_desc','Support Alina with your donation to help her treatment journey.') %></p>
                            </div>
                        </div>
                    </div>
                    <div class="premium-grid" id="homeProductGrid">
                        <% if (typeof products !=='undefined' && products.length> 0) { %>
                            <% products.forEach((product, index)=> {
                                const isHidden = index >= 16;
                                %>
                                <div class="premium-card <%= isHidden ? 'premium-card-hidden' : '' %>"
                                    data-price="<%= product.price %>"
                                    data-date="<%= product.createdAt ? product.createdAt.getTime() : 0 %>"
                                    style="<%= isHidden ? 'display: none !important;' : '' %>">
                                    <div class="premium-card-img-wrapper">
                                        <a href="/product/<%= product._id %>">
                                            <img src="<%= product.imageUrl %>" alt="<%= tProduct(product, 'name') %>"
                                                class="primary-img">
                                            <img src="<%= product.imageUrl %>" alt="<%= tProduct(product, 'name') %>"
                                                class="secondary-img" style="filter: brightness(0.95);">
                                        </a>
                                        <button class="fav-btn" data-id="<%= product._id %>">
                                            <i
                                                class="<%= (typeof userFavorites !== 'undefined' && userFavorites.includes(product._id.toString())) ? 'fas fa-heart text-danger' : 'far fa-heart' %>"></i>
                                        </button>
                                    </div>
                                    <div class="premium-card-info">
                                        <div class="premium-card-title"><a href="/product/<%= product._id %>">
                                                <%= tProduct(product, 'name') %>
                                            </a></div>
                                            <div class="premium-card-desc">
                                            <%= tProduct(product, 'description') ? tProduct(product, 'description').substring(0,30) + '...' : t('default_product_desc','Pırlanta Şıklığı') %>
                                        </div>
                                        <div class="premium-card-price-wrap">
                                            <span class="premium-card-price">₺ <%= product.price.toLocaleString('tr-TR') %></span>
                                        </div>
                                        <div class="card-actions">
                                            <a href="/product/<%= product._id %>" class="btn-premium-secondary"
                                                style="padding: 10px; font-size: 10px;"><%= t('btn_view','View') %></a>
                                            <button
                                                onclick="openHomeAddToCartModal('<%= product._id %>', '<%= tProduct(product, 'name') %>', '<%= product.price %>', '<%= product.imageUrl %>', '<%= product.paytrLink || '' %>')"
                                                class="btn-premium-primary"
                                                style="padding: 10px; font-size: 10px; flex: 1;"><%= t('btn_buy_now','Buy Now') %></button>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                                    <% } else { %>
                                        <div style="grid-column: 1 / -1; text-align: center; padding: 50px 0;">
                                            <p style="font-size: 16px; color: #888;"><%= t('no_products','Henüz ürün eklenmemiş.') %></p>
                                        </div>
                                        <% } %>
                    </div>
                    <!-- Expandable Show More Button -->
                    <div class="row justify-content-center" style="margin-top: 40px; margin-bottom: 20px;">
                        <div class="room-btn" id="showMoreContainer"
                            style="<%= (typeof products !== 'undefined' && products.length <= 16) ? 'display: none;' : 'display: flex;' %>">
                            <button id="btnShowMore" class="border-btn"
                                style="background: transparent; cursor: pointer; border: 1px solid #c49b45; padding: 15px 35px; font-weight: bold; text-transform: uppercase; font-size: 12px; letter-spacing: 2px; transition: all 0.3s ease; border-radius: 4px;">Daha
                                <%= t('show_more','Daha Fazla Göster') %></button>
                        </div>
                    </div>
                </div>
            </div>
            <!--? New Arrival End -->

            <!--? Dinamik Özel Reyonlar Başlangıcı -->
            <% if (typeof sections !=='undefined' && sections.length> 0) { %>
                <% sections.forEach(sec=> { %>
                    <% if (sec.products && sec.products.length> 0) { %>
                        <div class="new-arrival dynamic-section pt-50 pb-50"
                            style="border-top: 1px solid rgba(0,0,0,0.03);">
                            <div class="container">
                                <div class="row justify-content-center mb-40">
                                    <div class="col-xl-7 col-lg-8 col-md-10 text-center">
                                        <div class="section-tittle mb-20">
                                            <h2>
                                                <%= sec.title %>
                                            </h2>
                                            <p>Browse this curated section to complete your style.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="premium-grid">
                                    <% sec.products.forEach(product=> { %>
                                        <div class="premium-card">
                                            <div class="premium-card-img-wrapper">
                                                <a href="/product/<%= product._id %>">
                                                    <img src="<%= product.imageUrl %>" alt="<%= tProduct(product, 'name') %>"
                                                        class="primary-img">
                                                    <img src="<%= product.imageUrl %>" alt="<%= tProduct(product, 'name') %>"
                                                        class="secondary-img" style="filter: brightness(0.95);">
                                                </a>
                                                <button class="fav-btn" data-id="<%= product._id %>">
                                                    <i
                                                        class="<%= (typeof userFavorites !== 'undefined' && userFavorites.includes(product._id.toString())) ? 'fas fa-heart text-danger' : 'far fa-heart' %>"></i>
                                                </button>
                                            </div>
                                            <div class="premium-card-info">
                                                <div class="premium-card-title"><a href="/product/<%= product._id %>">
                                                        <%= tProduct(product, 'name') %>
                                                    </a></div>
                                                <div class="premium-card-desc">
                                                    <%= tProduct(product, 'description') ? tProduct(product, 'description').substring(0,30)
                                                        + '...' : t('default_product_desc','Pırlanta Şıklığı') %>
                                                </div>
                                                <div class="premium-card-price-wrap">
                                                    <span class="premium-card-price">₺ <%=
                                                            product.price.toLocaleString('tr-TR') %></span>
                                                    <% if (product.price> 1000) { %>
                                                        <span class="premium-card-old-price">₺ <%=
                                                                Math.round(product.price * 1.2).toLocaleString('tr-TR')
                                                                %></span>
                                                        <% } %>
                                                </div>
                                                <div class="card-actions">
                                                    <a href="/product/<%= product._id %>" class="btn-premium-secondary"
                                                        style="padding: 10px; font-size: 10px;">İncele</a>
                                                    <button
                                                        onclick="openHomeAddToCartModal('<%= product._id %>', '<%= tProduct(product, 'name') %>', '<%= product.price %>', '<%= product.imageUrl %>', '<%= product.paytrLink || '' %>', '<%= product.paytrLink || '' %>')"
                                                        class="btn-premium-primary"
                                                        style="padding: 10px; font-size: 10px; flex: 1;"><%= t('btn_buy_now','Buy Now') %></button>
                                                </div>
                                            </div>
                                        </div>
                                        <% }); %>
                                </div>
                            </div>
                        </div>
                        <% } %>
                            <% }); %>
                                <% } %>
                                    <!--? Dinamik Özel Reyonlar Bitişi -->

                                    <style>
                                        /* Custom CSS styling for premium sort dropdown and hidden items */
                                        .premium-card-hidden {
                                            display: none !important;
                                        }

                        .service-modern-card {
                            background: #ffffff;
                            border: 1px solid #eee3d2;
                            border-radius: 22px;
                            padding: 24px 20px;
                            height: 100%;
                            box-shadow: 0 10px 30px rgba(20, 12, 64, 0.04);
                            transition: transform 0.2s ease, box-shadow 0.2s ease;
                        }

                        .service-modern-card:hover {
                            transform: translateY(-3px);
                            box-shadow: 0 16px 40px rgba(20, 12, 64, 0.08);
                        }

                        .service-modern-icon {
                            width: 46px;
                            height: 46px;
                            display: inline-flex;
                            align-items: center;
                            justify-content: center;
                            border-radius: 14px;
                            background: linear-gradient(135deg, #140c40 0%, #2e2b5f 100%);
                            color: #fff;
                            margin-bottom: 14px;
                        }

                        .service-modern-icon svg {
                            width: 22px;
                            height: 22px;
                        }

                        .service-modern-card h5 {
                            font-size: 16px;
                            font-weight: 700;
                            color: #140c40;
                            margin-bottom: 8px;
                        }

                        .service-modern-card p {
                            font-size: 13px;
                            color: #6b7280;
                            line-height: 1.65;
                            margin-bottom: 0;
                        }
                                            transform: translateY(-2px);
                                        }
                                    </style>


                                    <script>
                                        document.addEventListener('DOMContentLoaded', function () {
                                            const grid = document.getElementById('homeProductGrid');
                                            const btnShowMore = document.getElementById('btnShowMore');
                                            const showMoreContainer = document.getElementById('showMoreContainer');

                                            let visibleLimit = 16;

                                            function updateVisibility() {
                                                if (!grid) return;
                                                const cards = Array.from(grid.querySelectorAll('.premium-card'));
                                                cards.forEach((card, index) => {
                                                    if (index < visibleLimit) {
                                                        card.style.setProperty('display', 'block', 'important');
                                                        card.classList.remove('premium-card-hidden');
                                                    } else {
                                                        card.style.setProperty('display', 'none', 'important');
                                                        card.classList.add('premium-card-hidden');
                                                    }
                                                });

                                                if (showMoreContainer) {
                                                    if (visibleLimit >= cards.length) {
                                                        showMoreContainer.style.setProperty('display', 'none', 'important');
                                                    } else {
                                                        showMoreContainer.style.setProperty('display', 'flex', 'important');
                                                    }
                                                }
                                            }

                                            if (btnShowMore) {
                                                btnShowMore.addEventListener('click', function () {
                                                    visibleLimit += 16;
                                                    updateVisibility();
                                                });
                                            }

                                            if (btnShowMore) {
                                                btnShowMore.addEventListener('click', function () {
                                                    visibleLimit += 16;
                                                    updateVisibility();
                                                });
                                            }

                                            updateVisibility();
                                        });

                                        let currentProduct = null;

                                        // Home add-to-cart modal
                                        function openHomeAddToCartModal(productId, productName, productPrice, productImage, paytrLink = '') {
                                            currentProduct = {
                                                _id: productId,
                                                name: productName,
                                                price: productPrice,
                                                imageUrl: productImage,
                                                paytrLink: paytrLink
                                            };

                                            const modal = document.getElementById('addToCartModal');
                                            const content = document.getElementById('modal-product-content');

                                            // Modal içeriğini doldur
                                            content.innerHTML = `
                                                <img src="${productImage}" alt="${productName}" style="width: 120px; height: 120px; object-fit: cover; border-radius: 12px; margin-bottom: 15px;">
                                                <h3 style="font-size: 18px; font-weight: 700; color: #140C40; margin-bottom: 8px;">${productName}</h3>
                                                <p style="font-size: 20px; font-weight: 700; color: #ff2020; margin-bottom: 20px;">₺${parseFloat(productPrice).toLocaleString('tr-TR')}</p>
                                                
                                                <div style="display: flex; gap: 10px; margin-top: 20px;">
                                                    <button onclick="closeAddToCartModal()" class="btn-premium-secondary" style="flex: 1; padding: 12px 20px; font-size: 14px;">Cancel</button>
                                                    <button onclick="addToCartFromHome()" class="btn-premium-primary" style="flex: 1; padding: 12px 20px; font-size: 14px;">Buy Now</button>
                                                </div>
                                            `;

                                            modal.style.display = 'flex';
                                            document.body.style.overflow = 'hidden';
                                        }

                                        function closeAddToCartModal() {
                                            const modal = document.getElementById('addToCartModal');
                                            modal.style.display = 'none';
                                            document.body.style.overflow = '';
                                        }

                                        // Ana sayfadan sepete ekleme
                                        function addToCartFromHome() {
                                            if (!currentProduct) return;

                                            // Eğer bu ürün için direkt PayTR Link varsa, direkt git
                                            if (currentProduct.paytrLink && currentProduct.paytrLink.trim() !== '') {
                                                console.log('🔗 PayTR Link Solutions kullanılıyor:', currentProduct.paytrLink);
                                                closeAddToCartModal();
                                                window.location.href = currentProduct.paytrLink;
                                                return;
                                            }

                                            // Form oluşturalım ve POST edelim
                                            const form = document.createElement('form');
                                            form.method = 'POST';
                                            form.action = '/cart/add';

                                            const productIdInput = document.createElement('input');
                                            productIdInput.type = 'hidden';
                                            productIdInput.name = 'productId';
                                            productIdInput.value = currentProduct._id;

                                            const qtyInput = document.createElement('input');
                                            qtyInput.type = 'hidden';
                                            qtyInput.name = 'quantity';
                                            qtyInput.value = '1';

                                            form.appendChild(productIdInput);
                                            form.appendChild(qtyInput);

                                            document.body.appendChild(form);
                                            form.submit();
                                        }

                                        // Modal dışına tıklandığında kapat
                                        window.addEventListener('click', function (event) {
                                            const addModal = document.getElementById('addToCartModal');
                                            if (event.target === addModal) {
                                                closeAddToCartModal();
                                            }
                                        });
                                    </script>

        </main>


        <!-- Product Add-to-Cart Modal -->
        <div id="addToCartModal" class="ring-size-modal"
            style="display:none; position:fixed; z-index:1100; left:0; top:0; width:100%; height:100%; overflow:hidden; background-color:rgba(0,0,0,0.6); backdrop-filter: blur(8px); justify-content:center; align-items:center;">
            <div class="ring-size-modal-content"
                style="background-color:#ffffff; margin:auto; padding:25px; border-radius:20px; width:90%; max-width:550px; box-shadow:0 20px 50px rgba(0,0,0,0.15); border:1px solid rgba(196,155,69,0.2); position:relative; animation: modalFadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1); max-height: 95vh; overflow-y: auto;">
                <span class="ring-size-close" onclick="closeAddToCartModal()"
                    style="color:#aaa; position:absolute; right:20px; top:15px; font-size:28px; font-weight:bold; cursor:pointer; transition:color 0.2s; z-index: 10;">&times;</span>

                <div id="modal-product-content" style="text-align: center;">
                    <!-- Product content is dynamically filled here -->
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>
