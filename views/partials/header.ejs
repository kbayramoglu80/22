<style>
    .custom-header {
        font-family: 'Poppins', 'Inter', 'Roboto', sans-serif;
        background: #ffffff;
        border-bottom: 1px solid rgba(0, 0, 0, 0.08);
        box-shadow: 0 4px 18px rgba(0, 0, 0, 0.08);
        position: fixed;
        top: 0;
        left: 0;
        z-index: 1030;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        width: 100%;
        margin: 0;
        padding: 0;
        animation: headerFadeIn 0.8s ease both;
        transition: transform 0.35s ease, opacity 0.35s ease;
        will-change: transform, opacity;
    }

    .custom-header.header-hidden {
        transform: translateY(-110%);
        opacity: 0;
    }

    @keyframes headerFadeIn {
        from {
            opacity: 0;
            transform: translateY(-18px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .custom-header .container-fluid {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 15px;
    }

    /* Top Row - Logo and Top Icons */
    .header-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 0;
        width: 100%;
    }

    .header-logo {
        flex: 1;
        text-align: left;
        position: relative;
    }

    .header-logo a {
        display: inline-flex;
        align-items: center;
        justify-content: flex-start;
        text-decoration: none;
        background: transparent;
        padding: 0;
        border-radius: 0;
        width: auto;
        max-width: 260px;
        min-height: auto;
    }

    .header-logo img {
        height: 127px;
        width: auto;
        max-width: 200px;
        object-fit: contain;
        display: block;
    }

    /* Top Right Icons */
    .header-top-icons {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-left: auto;
    }

    .header-top-icons a {
        color: #333333;
        font-size: 16px;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .header-top-icons a:hover {
        color: #1f3a66;
    }

    .lang-switcher {
        display: inline-flex;
        gap: 8px;
        padding: 5px;
        border-radius: 999px;
        background: rgba(111, 120, 255, 0.08);
        border: 1px solid rgba(111, 120, 255, 0.16);
    }

    .lang-switcher-item {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: #ffffff;
        color: #333333;
        font-size: 18px;
        text-decoration: none;
        border: 1px solid transparent;
        transition: transform 0.25s ease, background 0.25s ease, border-color 0.25s ease;
    }

    .lang-switcher-item:hover {
        transform: translateY(-1px);
        border-color: rgba(111, 120, 255, 0.28);
    }

    .lang-switcher-item.active {
        background: linear-gradient(135deg, #5b6bff, #aa76ff);
        color: #ffffff;
        box-shadow: 0 10px 24px rgba(91, 107, 255, 0.16);
        border-color: rgba(255, 255, 255, 0.24);
    }

    /* Navigation Row */
    .header-middle {
        padding: 0;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
        background: transparent;
        width: 100%;
    }

    .header-nav {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 35px;
        list-style: none;
        margin: 0;
        padding: 12px 0;
    }

    .header-nav li {
        display: flex;
        align-items: center;
    }

    .header-nav a {
        color: #333333;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.3s ease;
        letter-spacing: 0.5px;
        padding: 6px 0;
        position: relative;
        animation: navLinkFadeIn 0.7s ease both;
    }

    .header-nav a:hover {
        color: #1f3a66;
    }

    .header-nav li:nth-child(2) a { animation-delay: 0.05s; }
    .header-nav li:nth-child(3) a { animation-delay: 0.1s; }
    .header-nav li:nth-child(4) a { animation-delay: 0.15s; }
    .header-nav li:nth-child(5) a { animation-delay: 0.2s; }
    .header-nav li:nth-child(6) a { animation-delay: 0.25s; }

    @keyframes navLinkFadeIn {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .header-nav a:hover {
        color: #d9c7ff;
    }

    .header-nav a::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: 0;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, #d9c7ff, #8da4ff);
        transform: scaleX(0);
        transform-origin: center;
        transition: transform 0.3s ease;
    }

    .header-nav a:hover::after {
        transform: scaleX(1);
    }

    /* Search Bar in Header Middle */
    .header-search {
        display: none;
    }

    /* Icons in middle nav */
    .header-icons {
        display: none;
    }

    .header-bottom {
        display: none;
    }

    .header-promo-nav {
        display: none;
    }

    /* Mobile styles */
    @media (max-width: 991px) {
        .header-top {
            display: flex !important;
            padding: 16px 0;
        }

        .header-middle,
        .header-bottom,
        .mobile-header-top,
        .mobile-search-wrapper,
        .mobile_menu {
            display: none !important;
        }
    }
</style>

<header class="custom-header">
    <div class="container-fluid">
        <div class="header-top">
            <div style="display:flex; align-items:center; gap:10px;">
                <div class="lang-switcher" role="group" aria-label="<%= t('language_switch','Dil Değiştir') %>">
                    <a href="/lang/tr" class="lang-switcher-item <%= (locals.currentLang === 'tr') ? 'active' : '' %>" aria-label="Türkçe">🇹🇷</a>
                    <a href="/lang/en" class="lang-switcher-item <%= (locals.currentLang === 'en') ? 'active' : '' %>" aria-label="English">🇬🇧</a>
                    <a href="/lang/ru" class="lang-switcher-item <%= (locals.currentLang === 'ru') ? 'active' : '' %>" aria-label="Русский">🇷🇺</a>
                </div>
            </div>

            <div class="header-logo" style="flex: 1; text-align: center;">
                <a href="/" style="display: inline-flex; align-items: center; justify-content: center; text-decoration: none; color: #111111; font-size: 24px; font-weight: 700; letter-spacing: 0.08em;">
                    <%= t('site_name', 'Alina İçin Destek') %>
                </a>
            </div>

            <div style="width: 48px;"></div>
        </div>

        <div class="header-middle d-none d-lg-block">
            <div class="container-fluid">
                <ul class="header-nav">
                    <% if (user && user.role === 'admin') { %>
                        <li><a href="/admin" style="color: #d9534f; font-weight: bold;">Admin</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </div>
</header>

<!-- Hidden nav for Slicknav to build mobile menu -->
<div class="d-none">
        <ul id="navigation">
        <li><a href="<%= user ? '/user/profile' : '/auth/login' %>">
                <%= user ? t('account','Hesabım') : t('login_register','Giriş Yap / Kayıt Ol') %>
            </a></li>
        <li><a href="/user/favorites"><%= t('favorites','Favorilerim') %></a></li>
        <% if (user && user.role==='admin' ) { %>
            <li><a href="/admin"><%= t('admin_panel','Admin Paneli') %></a></li>
        <% } %>
    </ul>
</div>

<!-- Mobile Interaction Logic -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // 1. Mobile Search Box Toggle Logic
        const searchBtn = document.getElementById('mobileSearchBtn');
        const searchWrapper = document.getElementById('mobileSearchWrapper');
        const hasJQuery = typeof $ === 'function';

        if (searchBtn && searchWrapper) {
            searchBtn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                try {
                    if (hasJQuery) {
                        const nav = $('ul#navigation');
                        if (nav.length && typeof nav.slicknav === 'function' && nav.slicknav('isOpen')) {
                            nav.slicknav('close');
                            const menuIcon = document.querySelector('#mobileMenuBtn i');
                            if (menuIcon) menuIcon.className = 'fas fa-bars';
                        }
                    }
                } catch (err) {
                    // ignore plugin errors for mobile search toggle
                }

                const isHidden = window.getComputedStyle(searchWrapper).display === 'none';
                if (isHidden) {
                    searchWrapper.style.display = 'block';
                    searchBtn.innerHTML = '<i class="fas fa-times"></i>';
                    searchBtn.style.color = '#d9534f';
                    const input = searchWrapper.querySelector('input');
                    if (input) input.focus();
                } else {
                    searchWrapper.style.display = 'none';
                    searchBtn.innerHTML = '<i class="fas fa-search"></i>';
                    searchBtn.style.color = '';
                }
            });
        }

        // 2. Custom Mobile Menu (Slicknav Wrapper) Toggle Logic
        const menuBtn = document.getElementById('mobileMenuBtn');
        if (menuBtn) {
            menuBtn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                if (searchWrapper && window.getComputedStyle(searchWrapper).display !== 'none') {
                    searchWrapper.style.display = 'none';
                    if (searchBtn) {
                        searchBtn.innerHTML = '<i class="fas fa-search"></i>';
                        searchBtn.style.color = '';
                    }
                }

                if (hasJQuery) {
                    try {
                        const nav = $('ul#navigation');
                        if (nav.length && typeof nav.slicknav === 'function') {
                            nav.slicknav('toggle');
                        }
                    } catch (err) {
                        // ignore if slicknav not loaded
                    }
                }

                const icon = menuBtn.querySelector('i');
                if (icon) {
                    if (icon.classList.contains('fa-bars')) {
                        icon.className = 'fas fa-times';
                    } else {
                        icon.className = 'fas fa-bars';
                    }
                }
            });
        }

        // Hide header on scroll down, show on scroll up
        const headerElement = document.querySelector('.custom-header');
        let lastScrollY = window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;
        const hideAfter = 40;

        function closeMobileInteractions() {
            if (searchWrapper && window.getComputedStyle(searchWrapper).display !== 'none') {
                searchWrapper.style.display = 'none';
                if (searchBtn) {
                    searchBtn.innerHTML = '<i class="fas fa-search"></i>';
                    searchBtn.style.color = '';
                }
            }

            if (hasJQuery) {
                try {
                    const nav = $('ul#navigation');
                    if (nav.length && typeof nav.slicknav === 'function') {
                        nav.slicknav('close');
                    }
                } catch (err) {
                    // ignore plugin errors for mobile menu close
                }
            }

            const menuIcon = document.querySelector('#mobileMenuBtn i');
            if (menuIcon && !menuIcon.classList.contains('fa-bars')) {
                menuIcon.className = 'fas fa-bars';
            }
        }

        window.addEventListener('scroll', function () {
            if (!headerElement) return;
            const currentScrollY = window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;

            if (currentScrollY > lastScrollY && currentScrollY > hideAfter) {
                headerElement.classList.add('header-hidden');
                closeMobileInteractions();
            } else if (currentScrollY < lastScrollY) {
                headerElement.classList.remove('header-hidden');
            }

            lastScrollY = currentScrollY;
        });

        // Close dropdowns if user clicks outside of header elements
        document.addEventListener('click', function (event) {
            const header = document.querySelector('.custom-header');
            if (header && !header.contains(event.target)) {
                if (searchWrapper && searchWrapper.style.display !== 'none') {
                    $(searchWrapper).slideUp(180);
                    if (searchBtn) {
                        searchBtn.innerHTML = '<i class="fas fa-search"></i>';
                        searchBtn.style.color = '';
                    }
                }
            }
        });
    });
</script>
