<%- include('partials/head') %>
<%- include('partials/header') %>

<main>
    <!-- Hero Section -->
    <section class="slider-area">
        <div class="single-slider slider-height2 d-flex align-items-center">
            <div class="container">
                <div class="row">
                    <div class="col-xl-12">
                        <div class="hero-cap text-center">
                            <h2><%= tProduct(product, 'name') || t('product_detail','Ürün Detayı') %></h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

            <!--? Product Details Start -->
            <section class="product_details section_padding" style="background-color: #ffffff;">
                <div class="pdp-wrapper">
                    <div class="row">
                        <!-- LEFT COLUMN: GALLERY -->
                        <div class="col-lg-7">
                            <div class="pdp-gallery-col">
                                <!-- Main Image / Video Area -->
                                <div class="pdp-main-image" id="main-image-container">
                                    <img src="<%= product.imageUrl %>" id="main-product-image" alt="<%= tProduct(product, 'name') %>">
                                    <video id="main-product-video" controls playsinline webkit-playsinline
                                        preload="metadata"
                                        style="display:none; width: 100%; height: auto; max-height: 600px; object-fit: contain;"></video>

                                    <!-- Slider Nav Buttons -->
                                    <button class="slider-btn prev-btn" onclick="prevImage()"><i
                                            class="fas fa-chevron-left"></i></button>
                                    <button class="slider-btn next-btn" onclick="nextImage()"><i
                                            class="fas fa-chevron-right"></i></button>
                                </div>

                                <!-- Thumbnails -->
                                <div class="pdp-thumbnails" id="pdp-thumb-list">
                                    <!-- Main Image as first thumb -->
                                    <div class="pdp-thumb active media-thumb"
                                        onclick="changeMedia(this, '<%= product.imageUrl %>', 'image')">
                                        <img src="<%= product.imageUrl %>" alt="">
                                    </div>
                                    <!-- Combined & Sorted DB Images & Video -->
                                    <% let allMedia=[]; if (product.images && product.images.length> 0) {
                                        product.images.forEach(img => {
                                        allMedia.push({ type: 'image', url: img.url, order: img.order || 0 });
                                        });
                                        }
                                        if (product.videoUrl) {
                                        let vOrder = (product.videoOrder !== undefined && product.videoOrder !== null) ?
                                        product.videoOrder : 99;
                                        allMedia.push({ type: 'video', url: product.videoUrl, order: vOrder });
                                        }
                                        allMedia.sort((a,b) => a.order - b.order);
                                        %>
                                        <% allMedia.forEach(media=> { %>
                                            <% if (media.type==='image' ) { %>
                                                <div class="pdp-thumb media-thumb"
                                                    onclick="changeMedia(this, '<%= media.url %>', 'image')">
                                                    <img src="<%= media.url %>" alt="">
                                                </div>
                                                <% } else if (media.type==='video' ) { %>
                                                    <div class="pdp-thumb media-thumb video-thumb"
                                                        onclick="changeMedia(this, '<%= media.url %>', 'video')">
                                                        <div class="video-overlay"><i class="fas fa-play"></i></div>
                                                        <img src="<%= product.imageUrl %>" alt="Video"
                                                            style="filter: brightness(0.6);">
                                                    </div>
                                                    <% } %>
                                                        <% }); %>
                                </div>
                            </div>
                        </div>

                        <!-- RIGHT COLUMN: PRODUCT INFO -->
                        <div class="col-lg-5">
                            <div class="pdp-info-col">
                                <span class="pdp-sku">SKU: <%= product._id.toString().substring(0,8).toUpperCase() %>
                                        </span>
                                <h1 class="pdp-title">
                                    <%= tProduct(product, 'name') %>
                                </h1>

                                <div class="pdp-price-area">
                                    <span class="pdp-current-price" id="pdp-price" data-base="<%= product.price %>">₺
                                        <%= product.price.toLocaleString('tr-TR') %></span>
                                </div>

                                <div class="pdp-description"
                                    style="font-size: 14px; color: var(--premium-gray); line-height: 1.6; margin-bottom: 30px;">
                                    <%= tProduct(product, 'description') %>
                                </div>

                                <!-- DİNAMİK METAL RENKLERİ -->
                                <% if (product.metalColor) { %>
                                    <div class="variation-group">
                                        <div class="variation-label"><%= t('metal_color','Altın Rengi') %> <span id="color-label">
                                                <%= product.metalColor %>
                                            </span></div>
                                        <div class="swatch-list">
                                            <% if (product.metalColor==='Beyaz Altın' ) { %>
                                                <div class="swatch-color swatch-white-gold active"
                                                    onclick="selectVariation(this, 'color', 'Beyaz Altın')"
                                                    title="Beyaz Altın"></div>
                                                <% } else if (product.metalColor==='Sarı Altın' ) { %>
                                                    <div class="swatch-color swatch-yellow-gold active"
                                                        onclick="selectVariation(this, 'color', 'Sarı Altın')"
                                                        title="Sarı Altın"></div>
                                                    <% } else if (product.metalColor==='Rose Gold' ||
                                                        product.metalColor==='Rose Altın' ) { %>
                                                        <div class="swatch-color swatch-rose-gold active"
                                                            onclick="selectVariation(this, 'color', 'Rose Gold')"
                                                            title="Rose Gold"></div>
                                                        <% } else { %>
                                                            <span class="badge badge-light"
                                                                style="padding: 6px 12px; font-weight: bold; background: #f0f0f0; border-radius: 4px;">
                                                                <%= product.metalColor %>
                                                            </span>
                                                            <% } %>
                                        </div>
                                    </div>
                                    <% } %>

                                        <% if (product.caratOptions && product.caratOptions.length> 0) { %>
                                            <div class="variation-group">
                                                <div class="variation-label"><%= t('carat_size','Karat Büyüklüğü') %> <small
                                                        class="text-muted">(<%= t('optional','Seçim İsteğe Bağlıdır') %>)</small> <span
                                                        id="carat-label"><%= t('not_selected','Seçilmedi') %></span></div>
                                                <div class="pill-list">
                                                    <% product.caratOptions.forEach(opt=> { %>
                                                        <div class="pill-item"
                                                            onclick="selectCaratOption(this, '<%= opt.carat %>', '<%= opt.price %>')">
                                                            <%= opt.carat %> ct
                                                        </div>
                                                        <% }); %>
                                                            <div class="pill-item active" id="pill-default-carat"
                                                                onclick="selectCaratOption(this, '', '<%= product.price %>')">
                                                                <%= t('remove_selection','Seçimi Kaldır') %></div>
                                                </div>
                                            </div>
                                            <% } %>
                                                <input type="hidden" id="selected-carat-input" value="">
                                                <input type="hidden" id="quantityInput" value="1">

                                                </div>

                                                <!-- ACTIONS -->
                                                <div class="pdp-actions"
                                                    style="display: flex; align-items: center; gap: 15px;">
                                                    <button id="btn-buy-now" class="btn-premium-primary" style="flex: 1;"
                                                        data-paytr-link="<%= product.paytrLink || '' %>"
                                                        onclick="handleCartAction('<%= product._id %>', true)"><%= t('btn_buy_now','Hemen Satın Al') %></button>
                                                    <button class="fav-btn fav-btn-pdp" data-id="<%= product._id %>"
                                                        style="width: 50px; height: 50px; border-radius: 50%; border: 2px solid #1a1a1a; background: #fff; color: #1a1a1a; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; cursor: pointer; transition: all 0.3s; flex-shrink: 0; padding: 0; outline: none;">
                                                        <i
                                                            class="<%= (typeof userFavorites !== 'undefined' && userFavorites.includes(product._id.toString())) ? 'fas fa-heart text-danger' : 'far fa-heart' %>"></i>
                                                    </button>
                                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
    <!-- Related Products Section -->
    <% if (product.categories && product.categories.length > 0) { %>
        <section class="related-products section_padding">
            <div class="container">
                <h2 class="section-title">Benzer Ürünler</h2>
                <p style="text-align: center; color: #999;">Benzer ürünler yakında eklenecektir.</p>
            </div>
        </section>
    <% } %>
</main>

<style>
    .product-gallery-wrapper {
        position: relative;
        margin-bottom: 20px;
    }

    .main-image-container {
        position: relative;
        width: 100%;
        aspect-ratio: 1;
        background: #f9f9f9;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .main-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
        cursor: zoom-in;
        transition: transform 0.3s ease;
    }

    .main-image:hover {
        transform: scale(1.02);
    }

    .gallery-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 44px;
        height: 44px;
        background: rgba(0, 0, 0, 0.7);
        color: white;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        z-index: 10;
        transition: all 0.3s ease;
    }

    .gallery-nav:hover {
        background: rgba(255, 32, 32, 0.9);
    }

    .prev-btn {
        left: 15px;
    }

    .next-btn {
        right: 15px;
    }

    .gallery-thumbnails {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding: 10px 0;
    }

    .thumbnail-item {
        width: 80px;
        height: 80px;
        background: #f9f9f9;
        border: 2px solid transparent;
        border-radius: 8px;
        cursor: pointer;
        overflow: hidden;
        flex-shrink: 0;
        transition: all 0.3s ease;
    }

    .thumbnail-item img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .thumbnail-item:hover {
        border-color: #ddd;
    }

    .thumbnail-item.active {
        border-color: #ff2020;
    }

    .product-info-wrapper {
        padding: 0 20px;
    }

    .product-header {
        margin-bottom: 20px;
    }

    .product-code {
        font-size: 12px;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0 0 10px 0;
    }

    .product-title {
        font-size: 2rem;
        font-weight: 800;
        color: #1a1a1a;
        margin: 0;
        line-height: 1.3;
    }

    .price-section {
        display: flex;
        align-items: center;
        gap: 15px;
        margin: 25px 0;
    }

    .current-price {
        font-size: 2.2rem;
        font-weight: 800;
        color: #ff2020;
    }

    .original-price {
        font-size: 1.2rem;
        color: #999;
        text-decoration: line-through;
    }

    .stock-status {
        margin-bottom: 20px;
    }

    .stock-available {
        color: #27ae60;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .stock-unavailable {
        color: #e74c3c;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .product-description {
        font-size: 1.05rem;
        line-height: 1.8;
        color: #555;
        margin-bottom: 30px;
    }

    .specifications-section {
        background: #f9f8f5;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .specifications-section h3 {
        font-size: 14px;
        font-weight: 800;
        text-transform: uppercase;
        color: #1a1a1a;
        margin-bottom: 15px;
        letter-spacing: 1px;
    }

    .specs-table {
        display: grid;
        gap: 12px;
    }

    .spec-row {
        display: flex;
        justify-content: space-between;
        padding-bottom: 10px;
        border-bottom: 1px solid #ede8df;
    }

    .spec-row:last-child {
        border-bottom: none;
    }

    .spec-label {
        font-size: 13px;
        color: #888;
        font-weight: 600;
    }

    .spec-value {
        font-size: 13px;
        color: #1a1a1a;
        font-weight: 700;
    }

    .variation-section {
        margin-bottom: 25px;
    }

    .variation-section h4 {
        font-size: 14px;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .color-options {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .color-swatch {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        cursor: pointer;
        border: 2px solid #ddd;
        transition: all 0.3s ease;
    }

    .color-swatch:hover {
        border-color: #1a1a1a;
    }

    .white-gold {
        background: linear-gradient(135deg, #f0f0f0, #ffffff);
    }

    .yellow-gold {
        background: linear-gradient(135deg, #ffd700, #ffed4e);
    }

    .rose-gold {
        background: linear-gradient(135deg, #b76e79, #f4a9b0);
    }

    .color-name {
        font-weight: 600;
        color: #1a1a1a;
    }

    .action-section {
        display: flex;
        gap: 12px;
        margin: 30px 0;
        flex-wrap: wrap;
    }

    .quantity-selector {
        display: flex;
        align-items: center;
        border: 2px solid #e1e1e1;
        border-radius: 8px;
        background: white;
        padding: 0;
    }

    .qty-btn {
        background: none;
        border: none;
        width: 40px;
        height: 44px;
        cursor: pointer;
        color: #888;
        font-size: 16px;
        transition: color 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .qty-btn:hover {
        color: #ff2020;
    }

    #quantityInput {
        width: 50px;
        border: none;
        background: transparent;
        text-align: center;
        font-weight: 700;
        font-size: 16px;
        outline: none;
    }

    .btn-add-cart,
    .btn-buy-now {
        flex: 1;
        padding: 14px 24px;
        border: none;
        border-radius: 8px;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        min-width: 150px;
    }

    .btn-add-cart {
        background: white;
        color: #1a1a1a;
        border: 2px solid #1a1a1a;
    }

    .btn-add-cart:hover:not(:disabled) {
        background: #1a1a1a;
        color: white;
    }

    .btn-buy-now {
        background: #1a1a1a;
        color: white;
    }

    .btn-buy-now:hover:not(:disabled) {
        background: #ff2020;
    }

    .btn-add-cart:disabled,
    .btn-buy-now:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .btn-favorite {
        width: 50px;
        height: 50px;
        border: 2px solid #1a1a1a;
        background: white;
        border-radius: 8px;
        cursor: pointer;
        font-size: 20px;
        color: #1a1a1a;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-favorite:hover {
        background: #1a1a1a;
        color: white;
    }

    .btn-favorite.active {
        background: #ff2020;
        border-color: #ff2020;
        color: white;
    }

    .additional-info {
        background: #f9f8f5;
        border-radius: 12px;
        padding: 20px;
        margin-top: 25px;
    }

    .additional-info p {
        font-size: 14px;
        color: #555;
        margin: 0 0 12px 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .additional-info p:last-child {
        margin-bottom: 0;
    }

    .additional-info i {
        color: #ff2020;
        width: 20px;
        text-align: center;
    }

    .section-title {
        font-size: 2rem;
        font-weight: 800;
        text-align: center;
        color: #1a1a1a;
        margin-bottom: 40px;
    }

    @media (max-width: 768px) {
        .product-info-wrapper {
            padding: 0;
        }

        .product-title {
            font-size: 1.5rem;
        }

        .current-price {
            font-size: 1.8rem;
        }

        .action-section {
            flex-direction: column;
        }

        .btn-add-cart,
        .btn-buy-now {
            width: 100%;
        }

        .btn-favorite {
            width: 100%;
        }

        .gallery-nav {
            width: 38px;
            height: 38px;
            font-size: 16px;
        }

        .main-image-container {
            aspect-ratio: auto;
            min-height: 400px;
        }
    }
</style>

<script>
    let currentGalleryIndex = 0;
    const galleryItems = [
        '<%- product.imageUrl || "/assets/img/gallery/popular1.png" %>',
        <% if (product.images && product.images.length > 0) { %>
            <% product.images.forEach((img, idx) => { %>
                <% if (img && img.url) { %>
                    '<%- img.url %>'<% if (idx < product.images.length - 1) { %>,<% } %>
                <% } %>
            <% }); %>
        <% } %>
    ].filter(url => url && url.trim() !== '');  // Remove empty strings

    function selectGalleryImage(element, imageSrc) {
        document.querySelectorAll('.thumbnail-item').forEach(el => el.classList.remove('active'));
        element.classList.add('active');
        document.getElementById('mainProductImage').src = imageSrc;
        currentGalleryIndex = galleryItems.indexOf(imageSrc);
    }

    function prevGalleryImage() {
        currentGalleryIndex = (currentGalleryIndex - 1 + galleryItems.length) % galleryItems.length;
        const thumbnails = document.querySelectorAll('.thumbnail-item');
        thumbnails[currentGalleryIndex].click();
    }

    function nextGalleryImage() {
        currentGalleryIndex = (currentGalleryIndex + 1) % galleryItems.length;
        const thumbnails = document.querySelectorAll('.thumbnail-item');
        thumbnails[currentGalleryIndex].click();
    }

    function increaseQty() {
        const input = document.getElementById('quantityInput');
        const maxQty = parseInt(input.max) || 1;
        if (parseInt(input.value) < maxQty) {
            input.value = parseInt(input.value) + 1;
        }
    }

    function decreaseQty() {
        const input = document.getElementById('quantityInput');
        if (parseInt(input.value) > 1) {
            input.value = parseInt(input.value) - 1;
        }
    }

    async function addToCart(productId, isBuyNow) {
        const quantityInput = document.getElementById('quantityInput');
        const quantity = quantityInput ? parseInt(quantityInput.value) : 1;
        const selectedCarat = document.getElementById('selected-carat-input') ? document.getElementById('selected-carat-input').value : '';
        const btn = isBuyNow ? document.getElementById('btn-buy-now') : document.getElementById('btn-add-cart');
        const originalText = btn ? btn.innerHTML : '';

        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> İşleniyor...';
        btn.disabled = true;

        try {
            const response = await fetch('/cart/add', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    productId: productId,
                    quantity: quantity,
                    selectedCarat: selectedCarat
                })
            });

            const data = await response.json();

            if (data.success) {
                if (isBuyNow) {
                    window.location.href = '/checkout?buyNow=1';
                } else {
                    alert('Ürün sepete başarıyla eklendi!');
                    document.getElementById('quantityInput').value = 1;
                }
            } else {
                alert('Hata: ' + (data.message || 'Bir hata oluştu'));
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Bir hata oluştu. Lütfen tekrar deneyin.');
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    // Favorite functionality
    document.addEventListener('DOMContentLoaded', function() {
        const favoriteBtn = document.getElementById('favoriteBtn');
        if (favoriteBtn) {
            favoriteBtn.addEventListener('click', async function() {
                const productId = this.getAttribute('data-product-id');
                try {
                    const response = await fetch('/user/toggle-favorite', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ productId: productId })
                    });

                    const data = await response.json();
                    if (data.success) {
                        this.classList.toggle('active');
                        if (this.classList.contains('active')) {
                            this.innerHTML = '<i class="fas fa-heart"></i>';
                        } else {
                            this.innerHTML = '<i class="far fa-heart"></i>';
                        }
                    }
                } catch (error) {
                    console.error('Error:', error);
                }
            });
        }
    });

    // Keep existing functions for compatibility
    function handleCartAction(productId, isBuyNow) {
        if (isBuyNow) {
            const btn = document.getElementById('btn-buy-now');
            const paytrLink = btn ? btn.getAttribute('data-paytr-link') : '';
            
            // Eğer bu ürün için direkt PayTR Link varsa, direkt git
            if (paytrLink && paytrLink.trim() !== '') {
                console.log('🔗 PayTR Link Solutions kullanılıyor:', paytrLink);
                window.location.href = paytrLink;
                return;
            }
        }
        
        // Normal flow: sepete ekle ve checkout'a git
        addToCart(productId, isBuyNow);
    }

    function selectCaratOption(element, carat, price) {
        element.parentElement.querySelectorAll('.pill-item').forEach(el => el.classList.remove('active'));
        element.classList.add('active');
        const caratLabel = document.getElementById('carat-label');
        const inputVal = document.getElementById('selected-carat-input');
        if (carat) {
            caratLabel.innerText = carat + ' ct';
            inputVal.value = carat;
        } else {
            caratLabel.innerText = 'Seçilmedi';
            inputVal.value = '';
        }
    }

    function selectVariation(element, type, value) {
        element.parentElement.querySelectorAll('.swatch-color').forEach(el => el.classList.remove('active'));
        element.classList.add('active');
        document.getElementById(type + '-label').innerText = value;
    }

    function updateQty(change) {
        const input = document.getElementById('qty-input');
        if (!input) return;
        let val = parseInt(input.value) + change;
        if (val < 1) val = 1;
        if (val > 10) val = 10;
        input.value = val;
    }

    function changeMedia(element, src, type) {
        const imgEl = document.getElementById('main-product-image');
        document.querySelectorAll('.pdp-thumb').forEach(t => t.classList.remove('active'));
        element.classList.add('active');
        if (type === 'image') {
            imgEl.src = src;
        }
    }

    function prevImage() {
        prevGalleryImage();
    }

    function nextImage() {
        nextGalleryImage();
    }
</script>

<%- include('partials/footer') %>
