<%- include('partials/head') %>
<%- include('partials/header') %>
<main>
    <div class="slider-area">
        <div class="single-slider slider-height2 d-flex align-items-center">
            <div class="container">
                <div class="row">
                    <div class="col-xl-12">
                            <div class="hero-cap text-center">
                            <h2><%= t('products','Ürünler') %></h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <section class="product-list-area padding-bottom" style="padding-top: 60px; padding-bottom: 80px;">
        <div class="container">
            <div class="row mb-4 align-items-center">
                <div class="col-md-8">
                    <h3 style="font-weight: 700; color: #111;"><%= t('all_products','Tüm ürünler') %></h3>
                    <p style="color: #555;"><%= t('products_desc','Ürün adı, görseli, fiyatı ve detay açıklamasıyla sade bir liste.') %></p>
                </div>
                    <div class="col-md-4 text-md-right" style="margin-top: 15px;">
                    <span style="color: #777; font-size: 14px;"><%= products.length %> <%= t('products_found','adet ürün bulunuyor') %></span>
                </div>
            </div>
            <div class="row">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(product => { %>
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="product-card" style="border: 1px solid #eee; border-radius: 18px; overflow: hidden; transition: transform .25s ease; background: #fff;">
                                <a href="/urunler/<%= product._id %>" style="text-decoration: none; color: inherit;">
                                    <div style="height: 260px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: #fafafa;">
                                        <img src="<%= product.imageUrl %>" alt="<%= tProduct(product, 'name') %>" style="max-height: 100%; max-width: 100%; object-fit: contain;">
                                    </div>
                                    <div style="padding: 20px;">
                                        <h4 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 10px;"> <%= tProduct(product, 'name') %></h4>
                                        <p style="color: #555; font-size: 0.95rem; line-height: 1.5; height: 60px; overflow: hidden;"> <%= tProduct(product, 'description') ? tProduct(product, 'description').substring(0, 120) : t('no_description','Açıklama yok.') %></p>
                                        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 18px;">
                                            <span style="font-size: 1rem; font-weight: 700; color: #1a1a1a;">₺ <%= product.price.toLocaleString('tr-TR') %></span>
                                            <span style="color: #1a73e8; font-weight: 700; font-size: 0.9rem;"><%= t('detail','Detay') %></span>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <h4 style="font-weight: 700; color: #333;">Henüz ürün bulunmuyor.</h4>
                        <p style="color: #666;">Lütfen daha sonra tekrar deneyin.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
</main>
<%- include('partials/footer') %>
